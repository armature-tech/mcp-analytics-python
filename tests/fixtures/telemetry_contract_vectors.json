{
  "_comment": "Shared cross-SDK telemetry contract vectors. Copies of this file live in all three SDK packages and must stay byte-identical. See packages/TELEMETRY-CONTRACT.md in the monorepo.",
  "placeholders": {
    "binary": "[binary removed]",
    "base64": "[base64 removed]",
    "redaction_failed": "[redaction failed]"
  },
  "extraction": [
    {
      "name": "injected_strips_and_exports_v1_fields",
      "mode": "injected",
      "args": {
        "q": "x",
        "telemetry": {
          "user_turn": 3,
          "user_intent": "find x",
          "agent_thinking": "searching",
          "user_frustration": "low"
        }
      },
      "expect_args": {
        "q": "x"
      },
      "expect_telemetry": {
        "user_turn": 3,
        "user_intent": "find x",
        "agent_thinking": "searching",
        "user_frustration": "low"
      }
    },
    {
      "name": "injected_normalizes_legacy_aliases",
      "mode": "injected",
      "args": {
        "q": "x",
        "telemetry": {
          "intent": "legacy intent",
          "context": "legacy thinking",
          "frustration_level": "high"
        }
      },
      "expect_args": {
        "q": "x"
      },
      "expect_telemetry": {
        "user_intent": "legacy intent",
        "agent_thinking": "legacy thinking",
        "user_frustration": "high"
      }
    },
    {
      "name": "injected_v1_wins_over_alias",
      "mode": "injected",
      "args": {
        "telemetry": {
          "user_intent": "v1",
          "intent": "legacy"
        }
      },
      "expect_args": {},
      "expect_telemetry": {
        "user_intent": "v1"
      }
    },
    {
      "name": "injected_drops_invalid_user_turn",
      "mode": "injected",
      "args": {
        "telemetry": {
          "user_turn": 0,
          "user_intent": "x"
        }
      },
      "expect_args": {},
      "expect_telemetry": {
        "user_intent": "x"
      }
    },
    {
      "name": "injected_without_telemetry_passthrough",
      "mode": "injected",
      "args": {
        "q": "x"
      },
      "expect_args": {
        "q": "x"
      },
      "expect_telemetry": null
    },
    {
      "name": "owned_leaves_args_and_exports_nothing",
      "mode": "owned",
      "args": {
        "q": "x",
        "telemetry": {
          "user_intent": "customer data",
          "intent": "also customer data"
        }
      },
      "expect_args": {
        "q": "x",
        "telemetry": {
          "user_intent": "customer data",
          "intent": "also customer data"
        }
      },
      "expect_telemetry": null
    },
    {
      "name": "scrub_strips_without_export",
      "mode": "scrub",
      "args": {
        "q": "x",
        "telemetry": {
          "user_intent": "sent by cached client",
          "context": "legacy alias"
        }
      },
      "expect_args": {
        "q": "x"
      },
      "expect_telemetry": null
    },
    {
      "name": "scrub_without_telemetry_passthrough",
      "mode": "scrub",
      "args": {
        "q": "x"
      },
      "expect_args": {
        "q": "x"
      },
      "expect_telemetry": null
    }
  ],
