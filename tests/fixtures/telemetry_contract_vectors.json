{
  "_comment": "Shared cross-SDK telemetry contract vectors. Copies of this file live in all three SDK packages and must stay byte-identical. See packages/TELEMETRY-CONTRACT.md in the monorepo.",
  "placeholders": {
    "binary": "[binary removed]",
    "base64": "[base64 removed]",
    "redaction_failed": "[redaction failed]"
  },
  "extraction": [
    {
      "name": "injected_strips_and_exports_current_fields_ignores_cached_user_turn",
      "mode": "injected",
      "args": {
        "q": "x",
        "telemetry": {
          "user_turn": 3,
          "user_intent": "find x",
          "agent_thinking": "searching",
          "user_frustration": "low"
        }
      },
      "expect_args": {
        "q": "x"
      },
      "expect_telemetry": {
        "user_intent": "find x",
        "agent_thinking": "searching",
        "user_frustration": "low"
      }
    },
    {
      "name": "injected_normalizes_legacy_aliases",
      "mode": "injected",
      "args": {
        "q": "x",
        "telemetry": {
          "intent": "legacy intent",
          "context": "legacy thinking",
          "frustration_level": "high"
        }
      },
      "expect_args": {
        "q": "x"
      },
      "expect_telemetry": {
        "user_intent": "legacy intent",
        "agent_thinking": "legacy thinking",
        "user_frustration": "high"
      }
    },
    {
      "name": "injected_v1_wins_over_alias",
      "mode": "injected",
      "args": {
        "telemetry": {
          "user_intent": "v1",
          "intent": "legacy"
        }
      },
      "expect_args": {},
      "expect_telemetry": {
        "user_intent": "v1"
      }
    },
    {
      "name": "injected_ignores_cached_user_turn",
      "mode": "injected",
      "args": {
        "telemetry": {
          "user_turn": 0,
          "user_intent": "x"
        }
      },
      "expect_args": {},
      "expect_telemetry": {
        "user_intent": "x"
      }
    },
    {
      "name": "injected_without_telemetry_passthrough",
      "mode": "injected",
      "args": {
        "q": "x"
      },
      "expect_args": {
        "q": "x"
      },
      "expect_telemetry": null
    },
    {
      "name": "owned_leaves_args_and_exports_nothing",
      "mode": "owned",
      "args": {
        "q": "x",
        "telemetry": {
          "user_intent": "customer data",
          "intent": "also customer data"
        }
      },
      "expect_args": {
        "q": "x",
        "telemetry": {
          "user_intent": "customer data",
          "intent": "also customer data"
        }
      },
      "expect_telemetry": null
    },
    {
      "name": "scrub_strips_without_export",
      "mode": "scrub",
      "args": {
        "q": "x",
        "telemetry": {
          "user_intent": "sent by cached client",
          "context": "legacy alias"
        }
      },
      "expect_args": {
        "q": "x"
      },
      "expect_telemetry": null
    },
    {
      "name": "scrub_without_telemetry_passthrough",
      "mode": "scrub",
      "args": {
        "q": "x"
      },
      "expect_args": {
        "q": "x"
      },
      "expect_telemetry": null
    }
  ],
  "sanitization": [
    {
      "name": "image_block_data_replaced",
      "value": {
        "type": "image",
        "data": "",
        "mimeType": "image/png"
      },
      "expect": {
        "type": "image",
        "data": "[binary removed]",
        "mimeType": "image/png"
      }
    },
    {
      "name": "audio_block_data_replaced",
      "value": {
        "type": "audio",
        "data": "QUFBQQ==",
        "mimeType": "audio/wav"
      },
      "expect": {
        "type": "audio",
        "data": "[binary removed]",
        "mimeType": "audio/wav"
      }
    },
    {
      "name": "resource_blob_replaced",
      "value": {
        "content": [
          {
            "type": "resource",
            "resource": {
              "uri": "file:///x.bin",
              "blob": "QUFBQQ=="
            }
          }
        ]
      },
      "expect": {
        "content": [
          {
            "type": "resource",
            "resource": {
              "uri": "file:///x.bin",
              "blob": "[binary removed]"
            }
          }
        ]
      }
    },
    {
      "name": "long_base64_string_replaced",
      "value": {
        "payload": ""
      },
      "expect": {
        "payload": "[base64 removed]"
      }
    },
    {
      "name": "embedded_base64_run_replaced",
      "value": {
        "note": "attached payload  ends here"
      },
      "expect": {
        "note": "attached payload [base64 removed] ends here"
      }
    },
    {
      "name": "data_uri_replaced",
      "value": "data:image/png;base64,QUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFB",
      "expect": "[base64 removed]"
    },
    {
      "name": "short_base64_kept",
      "value": "QUFBQQ==",
      "expect": "QUFBQQ=="
    },
    {
      "name": "long_prose_kept",
      "value": "the quick brown fox jumps over the lazy dog and keeps going the quick brown fox jumps over the lazy dog and keeps going the quick brown fox jumps over the lazy dog and keeps going the quick brown fox jumps over the lazy dog and keeps going the quick brown fox jumps over the lazy dog and keeps going the quick brown fox jumps over the lazy dog and keeps going the quick brown fox jumps over the lazy dog and keeps going the quick brown fox jumps over the lazy dog and keeps going the quick brown fox jumps over the lazy dog and keeps going the quick brown fox jumps over the lazy dog and keeps going",
      "expect": "the quick brown fox jumps over the lazy dog and keeps going the quick brown fox jumps over the lazy dog and keeps going the quick brown fox jumps over the lazy dog and keeps going the quick brown fox jumps over the lazy dog and keeps going the quick brown fox jumps over the lazy dog and keeps going the quick brown fox jumps over the lazy dog and keeps going the quick brown fox jumps over the lazy dog and keeps going the quick brown fox jumps over the lazy dog and keeps going the quick brown fox jumps over the lazy dog and keeps going the quick brown fox jumps over the lazy dog and keeps going"
    },
    {
      "name": "nested_arrays_and_objects",
      "value": [
        {
          "a": [
            "",
            "keep"
          ]
        },
        "keep too"
      ],
      "expect": [
        {
          "a": [
            "[base64 removed]",
            "keep"
          ]
        },
        "keep too"
      ]
    },
    {
      "name": "non_string_primitives_kept",
      "value": {
        "n": 42,
        "b": true,
        "z": null
      },
      "expect": {
        "n": 42,
        "b": true,
        "z": null
      }
    }
  ],
  "secret_redaction": [
    {
      "name": "aws_key_in_prose",
      "value_parts": ["temporary creds AKIA", "IOSFODNN7EXAMPLE for the deploy"],
      "expect": "temporary creds [redacted:aws-access-key-id] for the deploy"
    },
    {
      "name": "anthropic_key",
      "value_parts": ["sk-ant-api03-", "abcdefghij1234567890"],
      "expect": "[redacted:anthropic-api-key]"
    },
    {
      "name": "openai_key",
      "value_parts": ["sk-proj-", "AbCdEfGhIjKlMnOpQrStUv123456"],
      "expect": "[redacted:openai-api-key]"
    },
    {
      "name": "github_pat",
      "value_parts": ["push failed for ghp_", "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdef1234"],
      "expect": "push failed for [redacted:github-token]"
    },
    {
      "name": "github_fine_grained_pat",
      "value_parts": ["github_pat_", "11ABCDEFGHIJKLMNOPQRSTUV_abcdefghij"],
      "expect": "[redacted:github-token]"
    },
    {
      "name": "google_key",
      "value_parts": ["key=AIza", "SyA1234567890abcdefghijklmnopqrstuv"],
      "expect": "key=[redacted:google-api-key]"
    },
    {
      "name": "slack_token",
      "value_parts": ["xoxb-", "123456789012-abcdefABCDEF"],
      "expect": "[redacted:slack-token]"
    },
    {
      "name": "stripe_key",
      "value_parts": ["sk_live_", "4eC39HqLyjWDarjtT1zdp7dc"],
      "expect": "[redacted:stripe-key]"
    },
    {
      "name": "jwt_standalone",
      "value_parts": ["eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.", "eyJzdWIiOiIxMjM0NTY3ODkwIn0.", "dozjgNryP4J3jVmNHl0w5N_XgL0n3I9PlFUP0THsR8U"],
      "expect": "[redacted:jwt]"
    },
    {
      "name": "bearer_opaque_token",
      "value_parts": ["Authorization: Bearer ", "abcdef1234567890abcdef"],
      "expect": "Authorization: Bearer [redacted:bearer]"
    },
    {
      "name": "bearer_jwt_gets_jwt_label",
      "value_parts": ["Bearer eyJhbGciOiJIUzI1NiJ9.", "eyJmb28iOiJiYXIifQ.", "abcdefghij12345"],
      "expect": "Bearer [redacted:jwt]"
    },
    {
      "name": "basic_credentials",
      "value_parts": ["Basic ", "dXNlcjpzM2NyZXRwQHNz"],
      "expect": "Basic [redacted:basic]"
    },
    {
      "name": "connection_string_masks_password_only",
      "value_parts": ["postgres://admin:", "s3cr3t@db.example.com:5432/app"],
      "expect": "postgres://admin:[redacted:connection-string]@db.example.com:5432/app"
    },
    {
      "name": "pem_block",
      "value_parts": ["-----BEGIN RSA PRIVATE KEY-----\n", "MIIEowIBAAKCAQEA7bq0\nMIIEowIBAAKCAQEA7bq1\n", "-----END RSA PRIVATE KEY-----"],
      "expect": "[redacted:pem]"
    },
    {
      "name": "sensitive_kv_in_string",
      "value_parts": ["connect failed: password=", "hunter2 for admin"],
      "expect": "connect failed: password=[redacted:sensitive-kv] for admin"
    },
    {
      "name": "sensitive_field_names",
      "value": {
        "password": "hunter2",
        "apiKey": "abc",
        "client_secret": "xyz",
        "Authorization": "Bearer short",
        "token_count": 42,
        "note": "safe"
      },
      "expect": {
        "password": "[redacted:sensitive-field]",
        "apiKey": "[redacted:sensitive-field]",
        "client_secret": "[redacted:sensitive-field]",
        "Authorization": "[redacted:sensitive-field]",
        "token_count": 42,
        "note": "safe"
      }
    },
    {
      "name": "field_name_case_and_separator_insensitive",
      "value": {
        "PASSWORD": "x",
        "Api-Key": "y",
        "refresh_token": "z"
      },
      "expect": {
        "PASSWORD": "[redacted:sensitive-field]",
        "Api-Key": "[redacted:sensitive-field]",
        "refresh_token": "[redacted:sensitive-field]"
      }
    },
    {
      "name": "sensitive_key_wins_over_pattern_label",
      "value": {
        "config": {
          "database_url": "postgres://u:pw@h/db",
          "items": [
            "AKIAIOSFODNN7EXAMPLE"
          ]
        }
      },
      "expect": {
        "config": {
          "database_url": "[redacted:sensitive-field]",
          "items": [
            "[redacted:aws-access-key-id]"
          ]
        }
      }
    },
    {
      "name": "non_matches_pass_through",
      "value": {
        "uuid": "6f9619ff-8b86-d011-b42d-00c04fc964ff",
        "sha256": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
        "email": "user@example.com",
        "short_sk": "sk-abc",
        "prose_colon": "the secret: keep it safe"
      },
      "expect": {
        "uuid": "6f9619ff-8b86-d011-b42d-00c04fc964ff",
        "sha256": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
        "email": "user@example.com",
        "short_sk": "sk-abc",
        "prose_colon": "the secret: keep it safe"
      }
    },
    {
      "name": "base64_under_sensitive_key",
      "value": {
        "password": ""
      },
      "expect": {
        "password": "[redacted:sensitive-field]"
      }
    },
    {
      "name": "array_recursion",
      "value": [
        "AKIAIOSFODNN7EXAMPLE",
        "normal text"
      ],
      "expect": [
        "[redacted:aws-access-key-id]",
        "normal text"
      ]
    }
  ],
  "telemetry_sanitization": [
    {
      "name": "whole_value_base64_in_user_intent_removed",
      "telemetry": {
        "user_intent": [""],
        "agent_thinking": ["searching the archive"]
      },
      "expect": {
        "user_intent": "[base64 removed]",
        "agent_thinking": "searching the archive"
      }
    },
    {
      "name": "embedded_base64_run_in_agent_thinking_removed",
      "telemetry": {
        "user_intent": ["look up the attachment"],
        "agent_thinking": ["attached payload ", "", " ends here"]
      },
      "expect": {
        "user_intent": "look up the attachment",
        "agent_thinking": "attached payload [base64 removed] ends here"
      }
    },
    {
      "name": "short_base64_kept_in_telemetry",
      "telemetry": {
        "user_intent": ["ping QUFBQQ== token"],
        "agent_thinking": ["QUFBQQ=="]
      },
      "expect": {
        "user_intent": "ping QUFBQQ== token",
        "agent_thinking": "QUFBQQ=="
      }
    },
    {
      "name": "secrets_still_redacted_in_telemetry",
      "telemetry": {
        "user_intent": ["deploy using AKIA", "IOSFODNN7EXAMPLE"],
        "agent_thinking": ["password=", "hunter2 for admin"]
      },
      "expect": {
        "user_intent": "deploy using [redacted:aws-access-key-id]",
        "agent_thinking": "password=[redacted:sensitive-kv] for admin"
      }
    }
  ]
}
